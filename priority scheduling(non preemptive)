#include<stdio.h>
int main()
{
    int i,n;
    float avg_tat = 0 , avg_wt = 0 ;
    int process[20],at[20],bt[20],ct[20],tat[20],wt[20],rt[20];
    printf("==== this is a priority algorithm (non preemptive)====");
    printf("\nenter the number of total processes : ");
    scanf("%d",&n);

    printf("\n----input for arrival time---- ");
    for (i=0;i < n; i++)
    {
        process[i]=i+1;
        printf("\nenter the arrival time for process %d : ",i+1) ;
        scanf("%d",&at[i]);   
    }
    printf("\n----input for burst time ----");
    for(i=0;i<n;i++)
    {
        process[i]=i+1;
        printf("\nenter the burst time for process %d:" ,i+1 );
        scanf("%d",&bt[i]);
    }
    int priority[20];
    printf("\n----input for priority here----");
    for(i=0;i<n;i++)
    {
        process[i]=i+1;
        printf("\n enter the priority for %d process :",i+1);
        scanf("%d",&priority[i]);
    }
    int time=0,completed=0;
    int highest_pri_index=-1;
    int min_priority ;
    int is_completed[20]={0};
    while(completed < n)
    {
        min_priority=9999;
        highest_pri_index=-1;

        for(i=0;i<n;i++)
        {
            if((at[i]<=time) && (is_completed[i]==0))
            {
                if(priority[i]<min_priority)
                {
                    min_priority=priority[i];
                    highest_pri_index=i;
                }
                else if (priority[i]==min_priority)
                {
                    if(at[i] && at[i]<at[highest_pri_index])
                    {
                        highest_pri_index=i;                       
                    }
                }
            }
        }
        if(highest_pri_index==-1)
        {
            time++;
        }
        else
        {
            time+=bt[highest_pri_index];
                
                ct[highest_pri_index]=time;
                tat[highest_pri_index]=ct[highest_pri_index]-at[highest_pri_index];
                wt[highest_pri_index]=tat[highest_pri_index]-bt[highest_pri_index];
                avg_tat+=tat[highest_pri_index];
                avg_wt+=wt[highest_pri_index];
                is_completed[highest_pri_index]=1;
                completed++;
        }
    }
    avg_tat=avg_tat/n;
    avg_wt=avg_wt/n;
    printf("\nprocess\tat\tbt\tpriority\tct\ttat\twt\n");
    for(i=0;i<n;i++)
    {
        printf("p%d\t%d\t%d\t\t%d\t%d\t%d\t%d\n",process[i],at[i],bt[i],priority[i],ct[i],tat[i],wt[i]);
    }
    printf("the average turnaround time = %.2f",avg_tat);
    printf("\nthe average waiting time = %.2f",avg_wt);
    return 0;
}
